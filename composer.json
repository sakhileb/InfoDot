{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "algolia/algoliasearch-client-php": "^4.39",
        "beyondcode/laravel-websockets": "^1.14",
        "guzzlehttp/guzzle": "^7.10",
        "laravel/framework": "^10.50.2",
        "laravel/jetstream": "^3.3",
        "laravel/sanctum": "^3.3",
        "laravel/scout": "^10.25",
        "laravel/tinker": "^2.11",
        "livewire/livewire": "^2.12",
        "pusher/pusher-php-server": "^7.2",
        "staudenmeir/laravel-adjacency-list": "^1.13.11",
        "teamtnt/laravel-scout-tntsearch-driver": "^12.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/sail": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.12",
        "phpunit/phpunit": "^10.5"
        ,"spatie/laravel-ignition": "^2.4.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:auth": [
            "@php artisan test tests/Feature/AuthenticationFlowSmokeTest.php tests/Feature/AuthenticationTest.php tests/Feature/RegistrationTest.php tests/Feature/PasswordResetTest.php"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan vendor:publish --force --tag=livewire:assets --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "block-insecure": false,
            "ignore": [
                "PKSA-8qx3-n5y5-vvnd"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
